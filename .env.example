# Supabase configuration
SUPABASE_SERVICE_ROLE_KEY= <SUPABASE_SERVICE_ROLE_KEY>
NEXT_PUBLIC_SUPABASE_URL= <NEXT_PUBLIC_SUPABASE_URL>
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY= <NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY>

# OpenRouter configuration
OPENROUTER_API_KEY= <OPENROUTER_API_KEY>

# Mastra configuration
NEXT_PUBLIC_APP_URL=http://localhost:3000
MASTRA_STORAGE_URL= <MASTRA_STORAGE_URL>

# DEVS-FIRE configuration
DEVS_FIRE_BASE_URL=https://firesim.cs.gsu.edu/api
DEVS_FIRE_REQUEST_TIMEOUT_MS=180000
DEVS_FIRE_ENABLE_WINDFLOW=0 <DEVS_FIRE_ENABLE_WINDFLOW>
DEVS_FIRE_DIAGNOSTICS_KEY= <DEVS_FIRE_DIAGNOSTICS_KEY>

# Clerk Auth configuration  
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY= <NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY>
CLERK_SECRET_KEY= <CLERK_SECRET_KEY>
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/login
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/signup
NEXT_PUBLIC_CLERK_AFTER_SIGN_IN_URL=/dashboard
NEXT_PUBLIC_CLERK_AFTER_SIGN_UP_URL=/dashboard